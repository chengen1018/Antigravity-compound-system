# ============================================
# Antigravity Compound System — 環境變數範本
# 複製此檔為 .env.local 並填入實際值
# ============================================

# Repository 根目錄（絕對路徑）
COMPOUND_REPO_ROOT=d:\chengen\Antigravity-compound-system

# Gemini CLI 相關
# GEMINI_API_KEY=your-api-key-here

# Git 設定
GIT_AUTHOR_NAME=Compound Bot
GIT_AUTHOR_EMAIL=compound-bot@example.com

# Loop 設定
MAX_LOOP_ITERATIONS=5

# Log 保留天數
LOG_RETENTION_DAYS=14

# Daily Notes 目錄（Antigravity 對話要點手動放這裡）
DAILY_NOTES_DIR=reports\daily-notes
